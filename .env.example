# Bot V7 example environment. Do not put secrets in git.
BOT_V7_ENV=dev
BOT_V7_DB_URL=sqlite:///state/bot_v7_dev.sqlite
# MariaDB production-style persistence:
# BOT_V7_DB_URL=mysql+pymysql://tradeuser:<password>@127.0.0.1:3306/bots
BOT_V7_DEFAULT_MODE=SHADOW
BOT_V7_ENABLE_TESTNET=false
BOT_V7_ENABLE_LIVE=false

# Public Binance Spot Testnet market data. API keys are not required for klines.
BOT_V7_BINANCE_TESTNET_REST=https://testnet.binance.vision
BOT_V7_BINANCE_TESTNET_WS=wss://stream.testnet.binance.vision:9443/ws

# Future private testnet actions only. Never commit real values.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
